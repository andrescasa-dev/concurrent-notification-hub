{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFiles": ["<rootDir>/test/utils/load-env-test.ts"],
  "globalSetup": "<rootDir>/test/utils/setup.ts",
  "maxWorkers": 1
}
